{
	"appId": "com.stardesk.app",
	"appName": "Stardesk",
	"webDir": "dist",
	"server": {
		"androidScheme": "https"
	},
	"plugins": {
		"GoogleAuth": {
			"scopes": [
				"profile",
				"email"
			],
			"serverClientId": "REPLACE_ME_WITH_YOUR_WEB_CLIENT_ID.apps.googleusercontent.com",
			"forceCodeForRefreshToken": true
		}
	}
}
