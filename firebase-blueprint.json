{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "GroupChat": {
      "title": "GroupChat",
      "description": "A group chat room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "name", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "senderName", "text", "timestamp"]
    },
    "DirectChat": {
      "title": "DirectChat",
      "description": "A private chat between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" }
      },
      "required": ["id", "participants", "updatedAt"]
    },
    "Exam": {
      "title": "Exam",
      "description": "An exam record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "marks": { "type": "number" },
        "totalMarks": { "type": "number" },
        "percentage": { "type": "number" },
        "rank": { "type": "integer" }
      },
      "required": ["id", "name", "date", "marks", "totalMarks", "percentage"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/exams/{examId}": {
      "schema": "Exam",
      "description": "User exam records"
    },
    "/groups/{groupId}": {
      "schema": "GroupChat",
      "description": "Group chat rooms"
    },
    "/groups/{groupId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a group chat"
    },
    "/direct_chats/{chatId}": {
      "schema": "DirectChat",
      "description": "Direct chat sessions"
    },
    "/direct_chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a direct chat"
    }
  }
}
